	"scripts": {
		"start-prod": "NODE_ENV=prod node --no-warnings --loader ts-paths-esm-loader -r dotenv/config src/index.ts",
		"watch-dev": "nodemon --watch './**/*.ts' --exec 'NODE_ENV=dev node --no-warnings --experimental-specifier-resolution=node --loader ts-paths-esm-loader' -r dotenv/config src/index.ts",
