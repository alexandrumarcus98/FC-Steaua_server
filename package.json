{
	"name": "fc-steaua_server",
	"version": "1.0.0",
	"description": "",
	"main": "index.ts",
	"type": "module",
	"scripts": {
		"start-prod": "NODE_ENV=prod node --no-warnings --loader ts-paths-esm-loader -r dotenv/config index.ts",
		"watch-dev": "nodemon --watch './**/*.ts' --exec 'NODE_ENV=dev node --no-warnings --experimental-specifier-resolution=node --loader ts-paths-esm-loader' -r dotenv/config index.ts",
		"server-dev": "tsc-watch --onSuccess && npm run watch-dev",
		"server-prod": "tsc-watch --onSuccess && npm run start-prod"
	},
	"keywords": [
		"node",
		"typescript",
		"node.js",
		"boilerplate",
		"generator",
		"express",
		"rest",
		"api",
		"mongodb",
		"mongoose",
		"es6",
		"es7",
		"es8",
		"es9",
		"jest",
		"docker",
		"passport",
		"joi",
		"eslint",
		"prettier"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"@types/ip": "^1.1.2",
		"chalk": "^5.3.0",
		"compression": "^1.7.4",
		"cors": "^2.8.5",
		"cross-env": "^7.0.3",
		"dotenv": "^16.3.1",
		"express": "^4.18.2",
		"express-async-handler": "^1.2.0",
		"express-mongo-sanitize": "^2.2.0",
		"express-rate-limit": "^7.1.2",
		"express-request-logger": "^0.0.3",
		"express-requests-logger": "^4.0.0",
		"helmet": "^7.0.0",
		"http-status": "^1.7.3",
		"ip": "^1.1.8",
		"joi": "^17.11.0",
		"mongodb": "^6.2.0",
		"mongoose": "^7.6.3",
		"nodemon": "^3.0.1",
		"ts-node": "^10.9.1",
		"ts-paths-esm-loader": "^1.4.3",
		"tsc-watch": "^6.0.4",
		"xss": "^1.0.14"
	},
	"devDependencies": {
		"@types/cors": "^2.8.15",
		"@types/express": "^4.17.20",
